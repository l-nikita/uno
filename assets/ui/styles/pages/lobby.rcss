body {
    justify-content: space-between;
}

#players {
    width: 100%;
    height: 80%;
}

#start_container {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    flex-direction: row;
    flex: 0 0;
    width: 100%;
    margin-right: 7vw;
    margin-bottom: 5vh;
    gap: 2vw;
}

button {
    width: 15vw;
}