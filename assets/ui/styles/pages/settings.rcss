body {
    justify-content: space-between;
}

#settings {
    width: 100%;
    height: 60%;
    background: #16181d;
}

#settings div label {
    display: flex; 
    flex-direction: row; 
    width: auto; 
    height: auto; 
    align-items: center;
    gap: 1vw;
}

#back_container {
    width: 100%; 
    padding: 0 0 3.5vh 3.5vw;
}