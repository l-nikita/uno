body {
    justify-content: space-between;
}

#settings {
    width: 100%;
    height: 60%;
}

#settings div label {
    display: flex; 
    flex-direction: row; 
    width: auto; 
    height: auto; 
    align-items: center;
    gap: 1vw;
    margin-top: 4vh;
}

#back_container {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    width: 100%; 
    padding: 0 11.5vw 6vh 0;
}