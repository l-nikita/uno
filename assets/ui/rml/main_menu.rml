<rml>
<head>
    <title>Main Menu</title>
    <link type="text/rcss" href="../styles/rml.rcss"/>
    <link type="text/rcss" href="../styles/pages/main-menu.rcss"/>
</head>
<body>
    <img id="bg" src="../images/menu_bg.png" />

    <div class="title-container u-center">
        <p>Uno</p>
    </div>
    <div id="container_buttons" class="container u-center">
        <button id="start" class="u-center">
            <span>Start Game</span>
        </button>

        <button id="settings" class="u-center">
            <span>Settings</span>
        </button>

        <button id="quit" class="u-center">
            <span>Quit</span>
        </button>
    </div>

    <div id="quit_dlg">
        <div id="quit_dlg_window">
            <h2>Are you sure you want to leave?</h2>
            <div id="quit_dlg_container_buttons">
                <button id="yes" class="u-center">
                    <span>Yes</span>
                </button>

                <button id="no" class="u-center">
                    <span>No</span>
                </button>
            </div>
        </div>
    </div>
</body>
</rml>
